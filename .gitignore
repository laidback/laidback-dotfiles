# Local build artifacts
dist/
node_modules/

# Mise local state
.mise.local.toml

# Secrets — never commit
.secrets.act
*.local.toml
*.local.yaml
config.local

# User secrets (sops/age managed). Plaintext lives at $LAIDBACK_CONFIG/secrets.env,
# i.e. OUTSIDE this repo. These globs are belt-and-braces in case anyone
# attempts to drop a copy inside the repo tree. The encrypted .sops variant
# is intentionally NOT ignored — it is safe to commit.
secrets.env
**/secrets.env
home/.config/laidback/secrets.env
home/.config/sops/age/keys.txt

# Corporate proxy CA (provided per-machine, not in git)
ZscalerRootCA.pem

# OS
.DS_Store
*~
*.swp

# Per-user data (must be provided per-machine; never commit)
home/.aws/
home/.kube/
home/.config/glab-cli/
home/.config/.jira.d/
home/projects/*.code-workspace
# Exception: the canonical multi-root workspace ships with the dotfiles
!home/projects/laidback-system.code-workspace
home/projects/mise/
