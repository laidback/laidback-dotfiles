# ~/.config/git/config — managed by laidback-dotfiles (stowed from home/.config/git/config)
# Edit here; run `mise run bootstrap` to restow.

[user]
  name = Lukas Ciszewski
  email = lukas.ciszewski@gmail.com

[core]
  excludesFile = ~/.config/git/ignore
  attributesFile = ~/.config/git/attributes
  hooksPath = ~/.config/git/hooks
  editor = vim
  pager = delta

[init]
  defaultBranch = main

[pull]
  rebase = true

[rebase]
  autoStash = true

[push]
  autoSetupRemote = true

[fetch]
  prune = true

[diff]
  colorMoved = zebra

[merge]
  conflictstyle = zdiff3

[alias]
  lg  = log --oneline --graph --decorate --all
  st  = status -sb
  sw  = switch
  co  = checkout
  wip = commit -am 'wip'

# ── Identity by forge ────────────────────────────────────────────────────────
# Repos are organised as $XDG_PROJECTS_DIR/<forge>/<group>/<project>.
# (XDG_PROJECTS_DIR defaults to ~/projects — override in your shell before
# sourcing env.sh if you use a different root.)
#
# The default identity above is personal (github.com/laidback).
# The includeIf below overrides it for work repos on the Hilti forge.
# Add one block per additional forge you work with.
[includeIf "gitdir:~/projects/git.buts.hilti.cloud/"]
  path = ~/.config/git/work.config