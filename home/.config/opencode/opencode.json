{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "GithubMCP": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": {}
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse"
    },
    "memelord": {
      "type": "local",
      "command": [
        "node",
        "/Users/ciszluk/.local/share/mise/installs/node/latest/bin/memelord",
        "serve"
      ],
      "environment": {
        "MEMELORD_DIR": "/Users/ciszluk/.config/opencode/.memelord"
      },
      "enabled": true
    },
    "codemogger": {
      "type": "local",
      "command": [
        "node",
        "/Users/ciszluk/.local/share/mise/installs/node/latest/bin/codemogger",
        "mcp"
      ],
      "enabled": true
    }
  },
  "lsp": true,
  "plugin": [
    "oh-my-openagent@latest"
  ]
}
