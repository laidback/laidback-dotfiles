# laidback secrets template — safe to commit (no real values)
#
# This file is the canonical list of user-environment tokens the laidback
# stack expects. It is stowed to ~/.config/laidback/secrets.env.example.
#
# Workflow (one-time):
#   mise run secrets:init       # generates age key + .sops.yaml; seeds .sops file from this template
#   mise run secrets:edit       # opens secrets.env.sops in $EDITOR via sops; fill in values
#   mise run secrets:decrypt    # writes plaintext to $LAIDBACK_CONFIG/secrets.env (0600)
#   start a new shell           # env.sh auto-sources the decrypted file
#   mise run secrets:status     # shows which variables are SET / missing (no values)
#
# After editing, repeat `secrets:edit` (sops re-encrypts on save) and rerun
# `secrets:decrypt`. The encrypted .sops file is safe to commit anywhere
# (e.g. a private dotfiles-secrets repo). The decrypted plaintext file
# lives outside this git repo at $LAIDBACK_CONFIG/secrets.env and must
# never be committed.
#
# Format: dotenv. Values are sourced via `set -a; . secrets.env; set +a`,
# so they are exported into the environment of every shell.

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token (classic or fine-grained). Used by gh, hub, and any
# tool that respects $GITHUB_TOKEN.
GITHUB_TOKEN=

# ── GitLab ───────────────────────────────────────────────────────────────────
# glab personal access token. Also picked up by curl-based scripts.
GLAB_TOKEN=
GITLAB_TOKEN=

# ── Atlassian / Jira ─────────────────────────────────────────────────────────
# Email is your Atlassian account email; the API token is created at
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── Container registries ─────────────────────────────────────────────────────
GHCR_TOKEN=

# ── LLM / AI providers ───────────────────────────────────────────────────────
# Only fill in the ones you actually use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Cloud (use AWS profiles in ~/.aws/credentials when possible) ─────────────
# These are last-resort overrides; prefer SSO + named profiles.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
